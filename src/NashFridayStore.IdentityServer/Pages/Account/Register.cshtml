@page
@model NashFridayStore.IdentityServer.Pages.Account.Register
@{
    Layout = null;
    ViewData["Title"] = "Create Account";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - NashFriday Shop</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        body {
            background: radial-gradient(circle at top right, #1e293b, #0f172a);
        }
        .glass-card {
            background: rgba(255, 255, 255, 0.9);
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
            border: 1px solid rgba(255, 255, 255, 0.2);
        }
    </style>
</head>
<body class="antialiased font-sans text-slate-900">

<div class="min-h-screen flex items-center justify-center py-12 px-4 sm:px-6 lg:px-8">
    <div class="max-w-md w-full space-y-8 glass-card p-10 rounded-[2.5rem] shadow-2xl">
        
        <div class="text-center">
            <div class="flex flex-col items-center mb-6">
                <img src="/images/nashfridayshop_logo.svg" alt="NashFriday" class="h-24 w-auto mb-2" />
            </div>
            
            <h2 class="text-2xl font-bold text-slate-800 tracking-tight uppercase">
                Create Account
            </h2>
            <p class="mt-2 text-sm text-slate-500">
                Join NashFriday Shop today.
            </p>
        </div>

        <form method="post" class="mt-10 space-y-6">
            @Html.AntiForgeryToken()
            <input asp-for="@Model.ReturnUrl" type="hidden" />

            <div class="space-y-5">
                <div>
                    <label asp-for="Input.FullName" class="block text-xs font-bold text-slate-500 uppercase tracking-wider ml-1 mb-1">Full Name</label>
                    <input asp-for="Input.FullName"
                           class="block w-full px-4 py-4 border-2 border-slate-100 rounded-2xl text-slate-900 placeholder-slate-400 focus:outline-none focus:border-red-600 focus:ring-0 transition-all bg-white"
                           placeholder="Enter your full name" />
                    <span asp-validation-for="Input.FullName" class="text-xs text-rose-500 mt-1 ml-1 block font-medium"></span>
                </div>

                <div>
                    <label asp-for="Input.Email" class="block text-xs font-bold text-slate-500 uppercase tracking-wider ml-1 mb-1">Email</label>
                    <input asp-for="Input.Email"
                           class="block w-full px-4 py-4 border-2 border-slate-100 rounded-2xl text-slate-900 placeholder-slate-400 focus:outline-none focus:border-red-600 focus:ring-0 transition-all bg-white"
                           placeholder="Enter your email" />
                    <span asp-validation-for="Input.Email" class="text-xs text-rose-500 mt-1 ml-1 block font-medium"></span>
                </div>

                <div>
                    <label asp-for="Input.PhoneNumber" class="block text-xs font-bold text-slate-500 uppercase tracking-wider ml-1 mb-1">Phone Number (Optional)</label>
                    <input asp-for="Input.PhoneNumber"
                           class="block w-full px-4 py-4 border-2 border-slate-100 rounded-2xl text-slate-900 placeholder-slate-400 focus:outline-none focus:border-red-600 focus:ring-0 transition-all bg-white"
                           placeholder="0123456789" />
                    <span asp-validation-for="Input.PhoneNumber" class="text-xs text-rose-500 mt-1 ml-1 block font-medium"></span>
                </div>

                <div>
                    <label asp-for="Input.Password" class="block text-xs font-bold text-slate-500 uppercase tracking-wider ml-1 mb-1">Password</label>
                    <input asp-for="Input.Password" type="password"
                           class="block w-full px-4 py-4 border-2 border-slate-100 rounded-2xl text-slate-900 placeholder-slate-400 focus:outline-none focus:border-red-600 focus:ring-0 transition-all bg-white"
                           placeholder="••••••••" />
                    <span asp-validation-for="Input.Password" class="text-xs text-rose-500 mt-1 ml-1 block font-medium"></span>
                </div>

                <div>
                    <label asp-for="Input.ConfirmPassword" class="block text-xs font-bold text-slate-500 uppercase tracking-wider ml-1 mb-1">Confirm Password</label>
                    <input asp-for="Input.ConfirmPassword" type="password"
                           class="block w-full px-4 py-4 border-2 border-slate-100 rounded-2xl text-slate-900 placeholder-slate-400 focus:outline-none focus:border-red-600 focus:ring-0 transition-all bg-white"
                           placeholder="••••••••" />
                    <span asp-validation-for="Input.ConfirmPassword" class="text-xs text-rose-500 mt-1 ml-1 block font-medium"></span>
                </div>
            </div>

            <div class="flex flex-col gap-3">
                <button type="submit"
                        class="w-full py-4 px-4 border border-transparent text-sm font-black rounded-2xl text-white bg-red-600 hover:bg-slate-900 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-red-500 transition-all transform active:scale-[0.98] shadow-xl uppercase tracking-widest">
                    Register
                </button>
                <a asp-page="Login" asp-route-returnUrl="@Model.ReturnUrl"
                   class="w-full py-4 px-4 bg-white border-2 border-slate-200 text-sm font-black rounded-2xl text-slate-400 hover:bg-slate-50 hover:text-slate-600 transition-all text-center uppercase tracking-widest">
                    Back to Login
                </a>
            </div>
        </form>

        @if (!string.IsNullOrEmpty(Model.ErrorMessage))
        {
            <div class="mt-6 p-4 rounded-2xl bg-rose-50 border border-rose-100">
                <p class="text-sm text-rose-600 text-center font-medium">
                    @Model.ErrorMessage
                </p>
            </div>
        }

        <div class="mt-10 pt-8 border-t border-slate-100 text-center">
            <p class="text-xs text-slate-400 font-medium">
                &copy; @DateTime.Now.Year NashFriday. All rights reserved.
            </p>
        </div>
    </div>
</div>
</body>
</html>
