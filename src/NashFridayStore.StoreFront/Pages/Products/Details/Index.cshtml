@page "{ProductId:guid}"
@model NashFridayStore.StoreFront.Pages.Products.Details.IndexModel
@{
    ViewData["Title"] = Model.Product?.Name ?? "Product Details";
}

<div class="container mx-auto px-4 py-8 min-h-screen">
    @if (Model.Product != null)
    {
        <!-- Breadcrumbs -->
        <div class="text-sm breadcrumbs mb-8 text-base-content/50 font-bold uppercase tracking-widest">
            <ul>
                <li><a asp-page="/Index">Home</a></li>
                <li><a asp-page="/Products/Index">Products</a></li>
                <li><a asp-page="/Products/Index" asp-route-CategoryId="@Model.Product.CategoryId">@Model.Product.CategoryName</a></li>
                <li class="text-primary">@Model.Product.Name</li>
            </ul>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-start">
            <!-- Product Gallery -->
            <div class="space-y-4">
                <div class="bg-base-200 rounded-3xl overflow-hidden border border-base-200 shadow-xl group aspect-square">
                    <img src="@(string.IsNullOrEmpty(Model.Product.ImageUrl) ? $"https://placehold.co/800x800/png?text={Model.Product.Name.Replace(" ", "+")}" : Model.Product.ImageUrl)" 
                         alt="@Model.Product.Name" 
                         class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" />
                </div>
            </div>

            <!-- Product Info -->
            <div class="flex flex-col h-full">
                <div class="mb-6">
                    <div class="flex items-center gap-2 mb-4">
                        <span class="badge badge-primary font-bold px-4 py-3 border-none">@Model.Product.CategoryName</span>
                        @if (Model.Product.Status == Services.Products.ProductStatus.InStock)
                        {
                            <span class="badge badge-success badge-outline font-bold px-4 py-3">In Stock</span>
                        }
                        else
                        {
                            <span class="badge badge-error badge-outline font-bold px-4 py-3">@Model.Product.Status</span>
                        }
                    </div>
                    
                    <h1 class="text-4xl md:text-5xl font-black text-base-content mb-4 tracking-tight">@Model.Product.Name</h1>
                    
                    <div class="flex items-center gap-4 mb-6">
                        <div class="flex items-center gap-1">
                            @for (int i = 1; i <= 5; i++)
                            {
                                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" 
                                     class="w-5 h-5 @(i <= Model.Product.AverageStars ? "text-warning" : "text-base-300")">
                                    <path fill-rule="evenodd" d="M10.788 3.21c.448-1.077 1.976-1.077 2.424 0l2.082 5.007 5.404.433c1.164.093 1.636 1.545.749 2.305l-4.117 3.527 1.257 5.273c.271 1.136-.964 2.033-1.96 1.425L12 18.354 7.373 21.18c-.996.608-2.231-.29-1.96-1.425l1.257-5.273-4.117-3.527c-.887-.76-.415-2.212.749-2.305l5.404-.433 2.082-5.006z" clip-rule="evenodd" />
                                </svg>
                            }
                            <span class="text-sm font-black ml-2 text-warning">@Model.Product.AverageStars</span>
                            <span class="text-sm font-bold text-base-content/30">/ 5.0</span>
                        </div>
                        <div class="h-4 w-px bg-base-content/10"></div>
                        <span class="text-sm text-base-content/50 font-bold uppercase tracking-widest">Free Shipping</span>
                    </div>

                    <div class="text-3xl font-black text-primary mb-8">
                        $@Model.Product.PriceUsd.ToString("F2")
                    </div>

                    <div class="prose prose-lg text-base-content/70 max-w-none mb-10">
                        <p>@Model.Product.Description</p>
                    </div>
                </div>

                <!-- Actions -->
                <div class="mt-auto p-8 bg-base-200 rounded-3xl border border-base-200 shadow-inner">
                    <div class="flex flex-col sm:flex-row gap-4 items-center">
                        <div class="form-control">
                            <label class="label">
                                <span class="label-text font-black uppercase text-[10px] tracking-widest text-base-content/50">Quantity</span>
                            </label>
                            <div class="join border border-base-300 rounded-full bg-base-100 p-1">
                                <button class="btn btn-ghost btn-circle btn-sm join-item">-</button>
                                <input type="number" value="1" min="1" max="@Model.Product.Quantity" class="input input-sm join-item w-16 text-center font-bold focus:outline-none bg-transparent" />
                                <button class="btn btn-ghost btn-circle btn-sm join-item">+</button>
                            </div>
                        </div>
                        
                        <div class="flex-1 w-full pt-6 sm:pt-0">
                            <button class="btn btn-primary btn-block rounded-full h-14 text-primary-content font-black uppercase tracking-widest hover:scale-[1.02] active:scale-[0.98] transition-all group">
                                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-5 h-5 mr-2 group-hover:animate-bounce">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 3h1.386c.51 0 .955.343 1.087.835l.383 1.437M7.5 14.25a3 3 0 0 0-3 3h15.75m-12.75-3h11.218c1.121-2.3 2.1-4.684 2.924-7.138a60.114 60.114 0 0 0-16.536-1.84M7.5 14.25 5.106 5.272M6 20.25a.75.75 0 1 1-1.5 0 .75.75 0 0 1 1.5 0Zm12.75 0a.75.75 0 1 1-1.5 0 .75.75 0 0 1 1.5 0Z" />
                                </svg>
                                Add to Cart
                            </button>
                        </div>
                    </div>
                    
                    <div class="mt-6 flex items-center justify-center gap-6 text-base-content/40">
                        <div class="flex items-center gap-2 text-xs font-bold uppercase tracking-widest">
                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
                            </svg>
                            Secure Payment
                        </div>
                        <div class="flex items-center gap-2 text-xs font-bold uppercase tracking-widest">
                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 18.75a1.5 1.5 0 0 1-3 0m3 0a1.5 1.5 0 0 0-3 0m3 0h6m-9 0H3.375a1.125 1.125 0 0 1-1.125-1.125V14.25m17.25 4.5a1.5 1.5 0 0 1-3 0m3 0a1.5 1.5 0 0 0-3 0m3 0h1.125c.621 0 1.129-.504 1.129-1.125V11.25c0-.447-.25-.847-.643-1.04l-2.125-1.041a1.125 1.125 0 0 0-1.402.597L17.25 12.75M12 18.75V12.75m0 0V4.5m0 8.25H4.5" />
                            </svg>
                            Fast Delivery
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Feedbacks Section -->
        <div class="mt-20 border-t border-base-200 pt-16">
            <div class="flex flex-col lg:flex-row gap-16">
                <!-- Ratings Summary -->
                <div class="lg:w-1/3">
                    <div class="sticky top-8">
                        <h3 class="text-3xl font-black mb-8 tracking-tight">Feedbacks</h3>
                        
                        <div class="bg-base-200 rounded-3xl p-10 border border-base-200">
                            <div class="flex flex-col items-center text-center">
                                <div class="text-7xl font-black text-primary mb-2">
                                    @(Model.Ratings?.Average.ToString("F1") ?? "0.0")
                                </div>
                                <div class="flex items-center gap-1 mb-4">
                                    @for (int i = 1; i <= 5; i++)
                                    {
                                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" 
                                             class="w-6 h-6 @(i <= (Model.Ratings?.Average ?? 0) ? "text-warning" : "text-base-300/50")">
                                            <path fill-rule="evenodd" d="M10.788 3.21c.448-1.077 1.976-1.077 2.424 0l2.082 5.007 5.404.433c1.164.093 1.636 1.545.749 2.305l-4.117 3.527 1.257 5.273c.271 1.136-.964 2.033-1.96 1.425L12 18.354 7.373 21.18c-.996.608-2.231-.29-1.96-1.425l1.257-5.273-4.117-3.527c-.887-.76-.415-2.212.749-2.305l5.404-.433 2.082-5.006z" clip-rule="evenodd" />
                                        </svg>
                                    }
                                </div>
                                <p class="text-sm font-bold text-base-content/40 uppercase tracking-[0.2em]">Based on @(Model.Ratings?.TotalItems ?? 0) reviews</p>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Review List -->
                <div id="id-ratings-list" class="lg:w-2/3">
                    <div class="space-y-8">
                        @if (Model.Ratings != null && Model.Ratings.Items.Any())
                        {
                            <div class="space-y-8">
                                @foreach (var rating in Model.Ratings.Items)
                                {
                                    <div class="pb-8 border-b border-base-200 last:border-0 group">
                                        <div class="flex justify-between items-start mb-4">
                                            <div class="flex items-center gap-1">
                                                @for (int i = 1; i <= 5; i++)
                                                {
                                                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" 
                                                         class="w-4 h-4 @(i <= rating.Stars ? "text-warning" : "text-base-300")">
                                                        <path fill-rule="evenodd" d="M10.788 3.21c.448-1.077 1.976-1.077 2.424 0l2.082 5.007 5.404.433c1.164.093 1.636 1.545.749 2.305l-4.117 3.527 1.257 5.273c.271 1.136-.964 2.033-1.96 1.425L12 18.354 7.373 21.18c-.996.608-2.231-.29-1.96-1.425l1.257-5.273-4.117-3.527c-.887-.76-.415-2.212.749-2.305l5.404-.433 2.082-5.006z" clip-rule="evenodd" />
                                                    </svg>
                                                }
                                            </div>
                                            <span class="text-xs font-bold text-base-content/30 uppercase tracking-widest">@rating.CreatedAtUtc.ToString("MMM dd, yyyy")</span>
                                        </div>

                                        <div class="flex items-center gap-4 mb-3">
                                            <div class="avatar">
                                                <div class="w-10 rounded-full ring ring-primary ring-offset-base-100 ring-offset-2">
                                                    <img src="@(string.IsNullOrEmpty(rating.CustomerAvatarUrl) ? $"https://i.pravatar.cc/150?u={rating.CustomerName}" : rating.CustomerAvatarUrl)" alt="@rating.CustomerName" />
                                                </div>
                                            </div>
                                            <h4 class="font-black text-lg text-base-content group-hover:text-primary transition-colors">@rating.CustomerName</h4>
                                        </div>
                                        <p class="text-base-content/70 leading-relaxed">@rating.Comment</p>
                                    </div>
                                }
                            </div>

                            <!-- Pagination -->
                            @if (Model.Ratings.TotalPages > 1)
                            {
                                <div class="mt-12 flex items-center justify-center gap-4">
                                    <button
                                        type="button"
                                        hx-get="/Products/Details/@Model.ProductId"
                                        hx-vals='{ "pageIndex": "@(Model.Ratings.PageIndex - 1)" }'
                                        hx-trigger="click"
                                        hx-target="#id-ratings-list"
                                        hx-select="#id-ratings-list"
                                        hx-swap="outerHTML"
                                        class="btn btn-circle btn-ghost @(Model.Ratings.PageIndex == 0 ? "btn-disabled" : "")"
                                    >
                                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-5 h-5">
                                            <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5 8.25 12l7.5-7.5" />
                                        </svg>
                                    </button>
                                    
                                    <div class="text-xs font-black uppercase tracking-[0.2em] text-base-content/30">
                                        Page @(Model.Ratings.PageIndex + 1) of @Model.Ratings.TotalPages
                                    </div>

                                    <button
                                        type="button"
                                        hx-get="/Products/Details/@Model.ProductId"
                                        hx-vals='{ "pageIndex": "@(Model.Ratings.PageIndex + 1)" }'
                                        hx-trigger="click"
                                        hx-target="#id-ratings-list"
                                        hx-select="#id-ratings-list"
                                        hx-swap="outerHTML"
                                        class="btn btn-circle btn-ghost @(Model.Ratings.PageIndex + 1 >= Model.Ratings.TotalPages ? "btn-disabled" : "")"
                                    >
                                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-5 h-5">
                                            <path stroke-linecap="round" stroke-linejoin="round" d="m8.25 4.5 7.5 7.5-7.5 7.5" />
                                        </svg>
                                    </button>
                                </div>
                            }
                        }
                        else
                        {
                            <div class="bg-base-200 rounded-3xl p-12 text-center border border-dashed border-base-300">
                                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-12 h-12 mx-auto text-base-content/20 mb-4">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M7.5 8.25h9m-9 3h9m-9 3h3m-12 1.5h18a2.25 2.25 0 0 0 2.25-2.25V6.75A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25v10.5A2.25 2.25 0 0 0 4.5 13.5h3L10.5 16l3-2.5h3" />
                                </svg>
                                <p class="text-base-content/50 font-bold uppercase tracking-widest">No reviews yet for this product.</p>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="flex flex-col items-center justify-center py-20 text-center">
             <span class="loading loading-spinner loading-lg text-primary"></span>
             <p class="mt-4 text-base-content/50 font-bold uppercase tracking-widest">Loading Product Details...</p>
        </div>
    }
</div>
