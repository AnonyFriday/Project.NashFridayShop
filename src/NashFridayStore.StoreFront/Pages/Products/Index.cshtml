@page
@model NashFridayStore.StoreFront.Pages.Products.IndexModel
@{
    ViewData["Title"] = "Shop Products";
}

<div class="container mx-auto px-4 py-8 min-h-screen">
    <div id="id-products-page" class="flex flex-col md:flex-row gap-8">
        
        @* Sidebar Filters *@
        <aside class="w-full md:w-64 space-y-8">

            
            @* Search Bar *@
            <div>
                <h3 class="text-lg font-bold mb-4 uppercase tracking-widest text-base-content/50">Search</h3>
                <div class="relative group">
                    
                    <input 
                        id="id-sidebar-search" 
                        asp-for="SearchName"
                        placeholder="Search products..." 
                        hx-get="/Products/Index"
                        hx-vals='{"CategoryId": "@Model.CategoryId", "SortBy": "@Model.SortBy"}'
                        hx-trigger="input changed delay:500ms" 
                        hx-target="#id-products-page" 
                        hx-select="#id-products-page" 
                        hx-swap="outerHTML show:no-scroll" 
                        hx-push-url="true"
                        class="input input-bordered w-full focus:outline-none focus:border-primary pr-10" />
                    <div class="absolute inset-y-0 right-0 flex items-center pr-3 pointer-events-none text-base-content/30">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-5 h-5">
                            <path stroke-linecap="round" stroke-linejoin="round" d="m21 21-5.197-5.197m0 0A7.5 7.5 0 1 0 5.196 5.196a7.5 7.5 0 0 0 10.607 10.607Z" />
                        </svg>
                    </div>
                </div>
            </div>

            @* Filter by Categories *@
            <div>
                <h3 class="text-lg font-bold mb-4 uppercase tracking-widest text-base-content/50">Category</h3>
                <select class="select select-bordered w-full" 
                        asp-for="CategoryId"
                        hx-get="/Products/Index" 
                        hx-vals='{"SearchName": "@Model.SearchName", "SortBy": "@Model.SortBy"}'
                        hx-trigger="change" 
                        hx-target="#id-products-page"
                        hx-select="#id-products-page" 
                        hx-swap="outerHTML show:no-scroll"
                        hx-push-url="true">
                    <option value="">All Categories</option>
                    @if (Model.CategoryResponse?.Items != null)
                    {
                        foreach (var category in Model.CategoryResponse.Items)
                        {
                            <option value="@category.Id">@category.Name</option>
                        }
                    }
                </select>
            </div>

            @* Sort Filter *@
            <div>
                <h3 class="text-lg font-bold mb-4 uppercase tracking-widest text-base-content/50">Sort By</h3>
                <select class="select select-bordered w-full" 
                        asp-for="SortBy"
                        hx-get="/Products/Index" 
                        hx-vals='{"CategoryId": "@Model.CategoryId", "SearchName": "@Model.SearchName"}'
                        hx-trigger="change" 
                        hx-target="#id-products-page"
                        hx-select="#id-products-page" 
                        hx-swap="outerHTML show:no-scroll"
                        hx-push-url="true">
                    <option value="NameAsc">Name: A-Z</option>
                    <option value="NameDesc">Name: Z-A</option>
                    <option value="PriceAsc">Price: Low to High</option>
                    <option value="PriceDesc">Price: High to Low</option>
                    <option value="RatingDesc">Rating: High to Low</option>
                    <option value="RatingAsc">Rating: Low to High</option>
                </select>
            </div>
        </aside>

        <!-- Product Grid Area -->
        <main class="flex-1">
            <!-- Header Info -->
            <div class="flex justify-between items-center mb-8 bg-base-200 p-4 rounded-xl border border-base-300">
                <h2 class="text-xl font-bold">
                    @if (!string.IsNullOrEmpty(Model.SearchName))
                    {
                        <span>Results for "@Model.SearchName"</span>
                    }
                    else
                    {
                        <span>All Products</span>
                    }
                    <span class="ml-2 badge badge-ghost text-base-content/50">@(Model.ProductResponse?.TotalItems ?? 0)
                        Items
                    </span>
                </h2>
            </div>

            <!-- Grid of Products -->
            @if (Model.ProductResponse?.Items != null && Model.ProductResponse.Items.Any())
            {
                <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
                    @foreach (var product in Model.ProductResponse.Items)
                    {
                            <div
                                class="card bg-base-100 border border-base-200 hover:shadow-2xl transition-all duration-300 group overflow-hidden">
                                <figure class="relative h-64 overflow-hidden">
                                    <img src="@(string.IsNullOrEmpty(product.ImageUrl) ? $"https://placehold.co/400x400/png?text={product.Name.Replace(" ", "+")}" : product.ImageUrl)"
                                         alt="@product.Name"
                                         class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500" />
                                
                                    @if (product.IsNew)
                                    {
                                        <div class="absolute top-4 left-4 badge badge-primary font-bold">NEW</div>
                                    }
                                
                                    <!-- Hover Quick View Overlay -->
                                    <div
                                        class="absolute inset-0 bg-black/20 opacity-0 group-hover:opacity-100 transition-opacity flex items-center justify-center gap-2">
                                        <a asp-page="/Products/Details/Index" asp-route-id="@product.Id"
                                           class="btn btn-primary btn-sm px-6">View Details</a>
                                    </div>
                                </figure>
                            
                                <div class="card-body p-5">
                                    <div class="flex justify-between items-start">
                                        <div>
                                            <p class="text-xs text-base-content/50 uppercase tracking-widest mb-1">
                                                @product.CategoryName</p>
                                                <h3 class="card-title text-md group-hover:text-primary transition-colors">@product.Name
                                                </h3>
                                            </div>
                                        </div>
                                
                                        <div class="flex items-center gap-1 mt-2">
                                            @for (int i = 1; i <= 5; i++)
                                            {
                                                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"
                                                     class="w-4 h-4 @(i <= product.AverageStars ? "text-warning" : "text-base-300")">
                                                    <path fill-rule="evenodd"
                                                          d="M10.788 3.21c.448-1.077 1.976-1.077 2.424 0l2.082 5.007 5.404.433c1.164.093 1.636 1.545.749 2.305l-4.117 3.527 1.257 5.273c.271 1.136-.964 2.033-1.96 1.425L12 18.354 7.373 21.18c-.996.608-2.231-.29-1.96-1.425l1.257-5.273-4.117-3.527c-.887-.76-.415-2.212.749-2.305l5.404-.433 2.082-5.006z"
                                                          clip-rule="evenodd" />
                                                </svg>
                                            }
                                            <span class="text-xs text-base-content/50 ml-1">(@product.AverageStars)</span>
                                        </div>

                                        <div class="card-actions justify-between items-center mt-6">
                                            <span class="text-2xl font-black text-primary">$@product.PriceUsd.ToString("F2")</span>
                                            <button
                                                class="btn btn-ghost btn-circle btn-sm border border-base-300 hover:bg-primary hover:text-primary-content transition-all">
                                                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"
                                                     stroke-width="1.5" stroke="currentColor" class="w-5 h-5">
                                                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
                                                </svg>
                                            </button>
                                        </div>
                                    </div>
                                </div>
                            }
                </div>
            }
            else
            {
                <div class="text-center py-20 bg-base-200 rounded-3xl border-2 border-dashed border-base-300">
                    <div class="text-6xl mb-4">🔎</div>
                    <h3 class="text-2xl font-bold mb-2">No products found</h3>
                    <p class="text-base-content/50">Try adjusting your filters or search terms.</p>
                    <a asp-page="/Products/Index" class="btn btn-outline mt-6">Clear All Filters</a>
                </div>
            }
        </main>
    </div>
</div>
