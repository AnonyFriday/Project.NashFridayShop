@page
@model NashFridayStore.StoreFront.Pages.Products.IndexModel
@{
    ViewData["Title"] = "Shop Products";
}

<div class="container mx-auto px-4 py-8 min-h-screen">
    <div id="id-products-page" class="flex flex-col md:flex-row gap-8">
        
        @* Sidebar Filters *@
        <aside class="w-full md:w-72 h-fit space-y-8 p-4 bg-base-200 rounded-lg shadow-sm border border-base-200">

            @* Search Bar *@
            <div class="flex items-start justify-between mb-4">
                <h3 class="text-lg font-bold uppercase tracking-widest text-base-content/50">Search</h3>
                <button class="btn btn-ghost btn-xs btn-circle text-base-content/30 hover:text-primary transition-colors tooltip tooltip-left"
                        data-tip="Clear All Filters"
                        hx-get="/Products/Index"
                        hx-target="#id-products-page"   
                        hx-select="#id-products-page"
                        hx-swap="outerHTML show:no-scroll"
                        hx-push-url="true">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-4 h-4">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.993 0 3.181 3.183a8.25 8.25 0 0 0 13.803-3.7M4.031 9.865a8.25 8.25 0 0 1 13.803-3.7l3.181 3.182m0-4.991v4.99" />
                    </svg>
                </button>
            </div>
            <div class="relative group">
                
                <input 
                    id="id-sidebar-search" 
                    asp-for="SearchName"
                    placeholder="Search products..." 
                    hx-get="/Products/Index"
                    hx-vals='{"CategoryId": "@Model.CategoryId", "SortBy": "@Model.SortBy", "PageSize": "@Model.PageSize", "MinPrice": "@Model.MinPrice", "MaxPrice": "@Model.MaxPrice", "PageIndex": 0}'
                    hx-trigger="input changed delay:500ms, search" 
                    hx-target="#id-products-page" 
                    hx-select="#id-products-page" 
                    hx-swap="outerHTML show:no-scroll" 
                    hx-push-url="true"
                    class="input input-bordered w-full focus:outline-none focus:border-primary pr-10" />
                <div class="absolute inset-y-0 right-0 flex items-center pr-3 pointer-events-none text-base-content/30">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-5 h-5">
                        <path stroke-linecap="round" stroke-linejoin="round" d="m21 21-5.197-5.197m0 0A7.5 7.5 0 1 0 5.196 5.196a7.5 7.5 0 0 0 10.607 10.607Z" />
                    </svg>
                </div>
            </div>

            @* Filter by Categories *@
            <div>
                <h3 class="text-lg font-bold mb-4 uppercase tracking-widest text-base-content/50">Category</h3>
                <select class="select select-bordered w-full" 
                        asp-for="CategoryId"
                        hx-get="/Products/Index" 
                        hx-vals='{"SearchName": "@Model.SearchName", "SortBy": "@Model.SortBy", "PageSize": "@Model.PageSize", "MinPrice": "@Model.MinPrice", "MaxPrice": "@Model.MaxPrice", "PageIndex": 0}'
                        hx-trigger="change" 
                        hx-target="#id-products-page"
                        hx-select="#id-products-page" 
                        hx-swap="outerHTML show:no-scroll"
                        hx-push-url="true">
                    <option value="">All Categories</option>
                    @if (Model.CategoryResponse?.Items != null)
                    {
                        foreach (var category in Model.CategoryResponse.Items)
                        {
                            <option value="@category.Id">@category.Name</option>
                        }
                    }
                </select>
            </div>

            @* Price Range Filter - Using FORM to avoid trigger each first. must only be trigger when finishing typing both min and max *@
            @* Case 1: min finish typing, max in typing then no trigger happens for min *@
            @* Case 2: max finish typing, min in typing then no trigger happens for max, will trigger as long as min finish typing *@
            <div>
                <h3 class="text-lg font-bold mb-4 uppercase tracking-widest text-base-content/50">Price Range (USD)</h3>
                <div class="flex items-center gap-2">
                    <form
                        hx-get="/Products/Index"
                        hx-trigger="input changed delay:1s"
                        hx-vals='{"SearchName": "@Model.SearchName", "SortBy": "@Model.SortBy", "PageSize": "@Model.PageSize", "CategoryId": "@Model.CategoryId", "PageIndex": 0}'
                        hx-target="#id-products-page"
                        hx-select="#id-products-page"
                        hx-swap="outerHTML show:no-scroll"
                        hx-push-url="true">
                        
                        @* Not using Tag helper here to avoid invariant issues *@
                        <div class="flex items-center gap-2">
                            <input 
                                name="MinPrice"
                                value="@Model.MinPrice"
                                type="number"
                                min="0"
                                step="0.01"
                                placeholder="Min"
                                class="input input-bordered input-sm" />
                        
                            <span>-</span>

                            <input 
                                name="MaxPrice"
                                value="@Model.MaxPrice"
                                type="number"
                                min="0"
                                step="0.01"
                                placeholder="Max"
                                class="input input-bordered input-sm" />
                        </div>
                    </form>
                </div>
            </div>

            @* Sort Filter *@
            <div>
                <h3 class="text-lg font-bold mb-4 uppercase tracking-widest text-base-content/50">Sort By</h3>
                <select class="select select-bordered w-full" 
                        asp-for="SortBy"
                        hx-get="/Products/Index" 
                        hx-vals='{"CategoryId": "@Model.CategoryId", "SearchName": "@Model.SearchName", "PageSize": "@Model.PageSize", "MinPrice": "@Model.MinPrice", "MaxPrice": "@Model.MaxPrice", "PageIndex": 0}'
                        hx-trigger="change" 
                        hx-target="#id-products-page"
                        hx-select="#id-products-page" 
                        hx-swap="outerHTML show:no-scroll"
                        hx-push-url="true">
                    <option value="NameAsc">Name: A-Z</option>
                    <option value="NameDesc">Name: Z-A</option>
                    <option value="PriceAsc">Price: Low to High</option>
                    <option value="PriceDesc">Price: High to Low</option>
                    <option value="RatingDesc">Rating: High to Low</option>
                    <option value="RatingAsc">Rating: Low to High</option>
                </select>
            </div>

        </aside>

        <!-- Product Grid Area -->
        <main class="flex-1">
            <!-- Header Info -->
            <div class="flex flex-col sm:flex-row justify-between items-center mb-8 bg-base-200 p-4 rounded-xl border border-base-200 gap-4 shadow-sm">
                <div class="flex items-center gap-2">
                    <h2 class="text-xl font-bold">
                        @if (!string.IsNullOrEmpty(Model.SearchName))
                        {
                            <span>Results for "@Model.SearchName"</span>
                        }
                        else
                        {
                            <span>All Products</span>
                        }
                    </h2>
                    <span class="badge font-bold text-primary px-4 py-4 border-none shadow-sm">@(Model.ProductResponse?.TotalItems ?? 0) Items</span>
                </div>

                @* Pagination *@
                @if (Model.ProductResponse != null && Model.ProductResponse.TotalPages > 0)
                {
                    <div class="flex items-center gap-4">
                        @* Page Size Selector *@
                        <div class="flex items-center gap-2">
                            <span class="text-xs font-bold uppercase tracking-widest text-base-content/50 hidden md:inline">Show:</span>
                            <select class="select select-bordered select-xs md:select-sm font-bold" 
                                    asp-for="@Model.PageSize"
                                    hx-get="/Products/Index" 
                                    hx-vals='{"CategoryId": "@Model.CategoryId", "SearchName": "@Model.SearchName", "SortBy": "@Model.SortBy", "MinPrice": "@Model.MinPrice", "MaxPrice": "@Model.MaxPrice", "PageIndex": 0}'
                                    hx-trigger="change" 
                                    hx-target="#id-products-page" 
                                    hx-select="#id-products-page" 
                                    hx-swap="outerHTML show:no-scroll"
                                    hx-push-url="true">
                                <option value="8">8</option>
                                <option value="16">16</option>
                                <option value="24">24</option>
                                <option value="32">32</option>
                            </select>
                        </div>

                        @* Pagination *@
                        <div class="join rounded-lg shadow-sm">
                            @* Previous *@
                            @if (Model.PageIndex > 0)
                            {
                                <button class="join-item btn btn-xs md:btn-sm"
                                        hx-get="/Products/Index"
                                        hx-vals='{"CategoryId": "@Model.CategoryId", "SearchName": "@Model.SearchName", "SortBy": "@Model.SortBy", "PageSize": "@Model.PageSize", "PageIndex": @(Model.PageIndex - 1)}'
                                        hx-target="#id-products-page"
                                        hx-select="#id-products-page"
                                        hx-swap="outerHTML show:no-scroll"
                                        hx-push-url="true">«</button>
                            }

                            @* Current Page Label *@
                            <button class="join-item btn btn-xs md:btn-sm no-animation cursor-default btn-primary font-bold">
                                Page @(Model.PageIndex + 1) of @(Model.ProductResponse?.TotalPages)
                            </button>

                            @* Next *@
                            @if (@Model.PageIndex < (@Model.ProductResponse?.TotalPages ?? 0) - 1)
                            {
                                <button class="join-item btn btn-xs md:btn-sm"
                                        hx-get="/Products/Index"
                                        hx-vals='{"CategoryId": "@Model.CategoryId", "SearchName": "@Model.SearchName", "SortBy": "@Model.SortBy", "PageSize": "@Model.PageSize", "PageIndex": @(Model.PageIndex + 1)}'
                                        hx-target="#id-products-page"
                                        hx-select="#id-products-page"
                                        hx-swap="outerHTML show:no-scroll"
                                        hx-push-url="true">»</button>
                            }
                        </div>
                    </div>
                }
            </div>

            <!-- Grid of Products -->
            @if (Model.ProductResponse?.Items != null && Model.ProductResponse.Items.Any())
            {
                <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
                    @foreach (var product in Model.ProductResponse.Items)
                    {
                        <div class="card bg-base-100 border border-base-200 hover:shadow-2xl transition-all duration-300 group overflow-hidden">
                            <figure class="relative h-64 overflow-hidden">
                                <img src="@(string.IsNullOrEmpty(product.ImageUrl) ? $"https://placehold.co/400x400/png?text={product.Name.Replace(" ", "+")}" : product.ImageUrl)"
                                     alt="@product.Name"
                                     class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500" />
                                
                                @if (product.IsNew)
                                {
                                    <div class="absolute top-4 left-4 badge badge-primary font-bold">NEW</div>
                                }
                            
                                <!-- Hover Quick View Overlay -->
                                <div class="absolute inset-0 bg-black/20 opacity-0 group-hover:opacity-100 transition-opacity flex items-center justify-center gap-2">
                                    <a asp-page="/Products/Details/Index" asp-route-id="@product.Id"
                                       class="btn btn-primary btn-sm px-6">View Details</a>
                                </div>
                            </figure>
                        
                            <div class="card-body p-5">
                                <div class="flex justify-between items-start">
                                    <div>
                                        <p class="text-xs text-base-content/50 uppercase tracking-widest mb-1">
                                            @product.CategoryName</p>
                                        <h3 class="card-title text-md group-hover:text-primary transition-colors">@product.Name</h3>
                                    </div>
                                </div>
                            
                                <div class="flex items-center gap-1 mt-2">
                                    @for (int i = 1; i <= 5; i++)
                                    {
                                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"
                                             class="w-4 h-4 @(i <= product.AverageStars ? "text-warning" : "text-base-300")">
                                            <path fill-rule="evenodd"
                                                  d="M10.788 3.21c.448-1.077 1.976-1.077 2.424 0l2.082 5.007 5.404.433c1.164.093 1.636 1.545.749 2.305l-4.117 3.527 1.257 5.273c.271 1.136-.964 2.033-1.96 1.425L12 18.354 7.373 21.18c-.996.608-2.231-.29-1.96-1.425l1.257-5.273-4.117-3.527c-.887-.76-.415-2.212.749-2.305l5.404-.433 2.082-5.006z"
                                                  clip-rule="evenodd" />
                                        </svg>
                                    }
                                    <span class="text-xs text-base-content/50 ml-1">(@product.AverageStars)</span>
                                </div>
                            
                                <div class="flex justify-between items-center mt-4">
                                    <span class="text-xl font-black text-primary">$@product.PriceUsd.ToString("F2")</span>
                                    <button class="btn btn-ghost btn-circle btn-sm">
                                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"
                                             stroke-width="1.5" stroke="currentColor" class="w-5 h-5">
                                            <path stroke-linecap="round" stroke-linejoin="round"
                                                  d="M2.25 3h1.386c.51 0 .955.343 1.087.835l.383 1.437M7.5 14.25a3 3 0 0 0-3 3h15.75m-12.75-3h11.218c1.121-2.3 2.1-4.684 2.924-7.138a60.114 60.114 0 0 0-16.536-1.84M7.5 14.25 5.106 5.272M6 20.25a.75.75 0 1 1-1.5 0 .75.75 0 0 1 1.5 0Zm12.75 0a.75.75 0 1 1-1.5 0 .75.75 0 0 1 1.5 0Z" />
                                        </svg>
                                    </button>
                                </div>
                            </div>
                        </div>
                    }
                </div>


            }
            else
            {
                <div class="flex flex-col items-center justify-center py-20 text-center bg-base-100 rounded-3xl border-2 border-dashed border-base-300">
                    <div class="bg-base-200 p-6 rounded-full mb-4">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-12 h-12 text-base-content/30">
                            <path stroke-linecap="round" stroke-linejoin="round" d="m21 21-5.197-5.197m0 0A7.5 7.5 0 1 0 5.196 5.196a7.5 7.5 0 0 0 10.607 10.607Z" />
                        </svg>
                    </div>
                    <h3 class="text-xl font-bold mb-2">No products found</h3>
                    <p class="text-base-content/50">Try adjusting your filters or search terms.</p>
                    <a asp-page="/Products/Index" class="btn btn-outline mt-6">Clear All Filters</a>
                </div>
            }
        </main>
    </div>
</div>
