@page
@model NashFridayStore.StoreFront.Pages.Orders.IndexModel
@{
    ViewData["Title"] = "My Orders";
}

<div class="container mx-auto px-4 py-8">
    <div class="flex items-center gap-4 mb-8">
        <div class="p-3 bg-primary/10 rounded-2xl">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 text-primary" fill="none" viewBox="0 0 24 24"
                 stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                      d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z" />
            </svg>
        </div>
        <div>
            <h1 class="text-3xl font-bold">My Orders</h1>
            <p class="text-base-content/60">Track and manage your recent purchases</p>
        </div>
    </div>

    @if (!Model.Orders.Any())
    {
        <div class="card bg-base-200 border-2 border-dashed border-base-300">
            <div class="card-body items-center text-center py-16">
                <div class="w-20 h-20 bg-base-300 rounded-full flex items-center justify-center mb-4">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-10 w-10 opacity-20" fill="none" viewBox="0 0 24 24"
                         stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                              d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" />
                    </svg>
                </div>
                <h2 class="text-xl font-bold">No orders found</h2>
                <p class="text-base-content/60 mb-6">Looks like you haven't made any purchases yet.</p>
                <a href="/Products" class="btn btn-primary px-8">Start Shopping</a>
            </div>
        </div>
    }
    else
    {
        <div class="space-y-6">
            @foreach (var order in Model.Orders)
            {
                <div
                    class="card bg-base-100 shadow-xl border border-base-200 overflow-hidden group hover:border-primary/30 transition-all duration-300">
                    <!-- Order Header -->
                    <div class="bg-base-200/50 px-6 py-4 flex flex-wrap items-center justify-between gap-4">
                        <div class="flex items-center gap-6">
                            <div>
                                <p class="text-xs font-semibold uppercase tracking-wider text-base-content/50 mb-1">Order Date
                                </p>
                                <p class="font-medium">@order.CreatedAtUtc.ToString("MMM dd, yyyy")</p>
                            </div>
                            <div>
                                <p class="text-xs font-semibold uppercase tracking-wider text-base-content/50 mb-1">Total Price
                                </p>
                                <p class="font-bold text-primary">@order.Currency @order.TotalPriceInUsd.ToString("N2")</p>
                            </div>
                            <div>
                                <p class="text-xs font-semibold uppercase tracking-wider text-base-content/50 mb-1">Order #</p>
                                <p class="font-mono text-sm">@order.Id.ToString()</p>
                            </div>
                        </div>
                        <div class="flex items-center gap-2">
                            @{
                                var statusClass = order.OrderStatus.ToLower() switch
                                {
                                    "completed" => "badge-success",
                                    "pending" => "badge-warning",
                                    "Delivered" => "badge-error",
                                    _ => "badge-ghost"
                                };
                                var paymentClass = order.PaymentStatus.ToLower() switch
                                {
                                    "paid" => "badge-success",
                                    "pending" => "badge-warning",
                                    _ => "badge-ghost"
                                };
                            }
                            <div class="badge @statusClass badge-outline gap-2 py-3 px-4">
                                <span class="w-2 h-2 rounded-full bg-current"></span>
                                @order.OrderStatus
                            </div>
                            <div class="badge @paymentClass gap-2 py-3 px-4">
                                @order.PaymentStatus
                            </div>
                        </div>
                    </div>

                    <!-- Order Items -->
                    <div class="card-body p-0">
                        <div class="divide-y divide-base-200">
                            @foreach (var item in order.OrderItems)
                            {
                                <div
                                    class="px-6 py-4 flex items-center justify-between group/item hover:bg-base-200/30 transition-colors">
                                    <div class="flex items-center gap-4">
                                        <div
                                            class="w-16 h-16 bg-base-200 rounded-xl flex items-center justify-center overflow-hidden">
                                            <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 text-base-content/20" fill="none"
                                                 viewBox="0 0 24 24" stroke="currentColor">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                                      d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
                                            </svg>
                                        </div>
                                        <div>
                                            <h3 class="font-bold group-hover/item:text-primary transition-colors line-clamp-1">
                                                @item.ProductName</h3>
                                                <div class="flex items-center gap-2 mt-1">
                                                    <span class="badge badge-sm badge-ghost">@item.CategoryName</span>
                                                    <span class="text-sm text-base-content/50">Qty: @item.Quantity</span>
                                                </div>
                                            </div>
                                        </div>
                                        <div class="text-right font-semibold">
                                            @order.Currency @item.ProductUnitPriceInUsd
                                        </div>
                                    </div>
                                }
                            </div>
                        </div>

                        <!-- Footer Info -->
                        <div
                            class="px-6 py-4 bg-base-100 border-t border-base-200 flex justify-between items-center text-sm text-base-content/50">
                            <div class="flex items-center gap-4">
                                <span class="flex items-center gap-1">
                                    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24"
                                         stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                              d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                              d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                                    </svg>
                                    Address: @order.DeliveryAddress
                                </span>
                            </div>
                            <a href="/Products" class="btn btn-ghost btn-sm gap-2">
                                Go Shopping Again
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24"
                                     stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                          d="M14 5l7 7m0 0l-7 7m7-7H3" />
                                </svg>
                            </a>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
