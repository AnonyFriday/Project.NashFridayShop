<header class="sticky top-0 z-50 bg-base-100 shadow-sm">
    <!-- Top Row: Logo, Search, Icons -->
    <div class="navbar px-4 md:px-12 py-4 border-b border-base-200">
        <!-- Left: Logo (2/10) -->
        <div class="navbar-start w-full min-w-[100px]">
            <a asp-page="/Index" class="hover:opacity-80 transition-opacity">
                <!-- Simplified sizing: just use height (h-12 on mobile, h-20 on desktop) -->
                <img src="~/images/nashfridayshop_logo.svg" alt="NashFriday Store" class="h-12 w-auto max-w-full" />
            </a>
        </div>

        <!-- Center: Search Bar -->
        <div class="navbar-center hidden md:flex px-2">
            <div class="join shadow-sm">
                <!-- Uses min/max widths instead of percentage grid math -->
                <input type="search" placeholder="Search for gifts..." class="input input-bordered join-item w-full min-w-[100px] lg:min-w-[450px] max-w-[600px] bg-base-100 border-base-300 focus:outline-none focus:border-primary" />
                <button class="btn btn-primary join-item px-6">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-5 h-5 text-primary-content">
                        <path stroke-linecap="round" stroke-linejoin="round" d="m21 21-5.197-5.197m0 0A7.5 7.5 0 1 0 5.196 5.196a7.5 7.5 0 0 0 10.607 10.607Z" />
                    </svg>
                </button>
            </div>
        </div>
    
        <!-- Right: Icons & Auth (3/10) -->
        <div class="navbar-end gap-2 md:gap-4 md:w-[30%] justify-end">

            <!-- Cart Dropdown -->
            <div class="dropdown dropdown-end">
                <div tabindex="0" role="button" class="btn btn-ghost btn-circle text-base-content/70 hover:text-primary">
                    <div class="indicator">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 3h1.386c.51 0 .955.343 1.087.835l.383 1.437M7.5 14.25a3 3 0 0 0-3 3h15.75m-12.75-3h11.218c1.121-2.3 2.1-4.684 2.924-7.138a60.114 60.114 0 0 0-16.536-1.84M7.5 14.25 5.106 5.272M6 20.25a.75.75 0 1 1-1.5 0 .75.75 0 0 1 1.5 0Zm12.75 0a.75.75 0 1 1-1.5 0 .75.75 0 0 1 1.5 0Z" />
                        </svg>
                        <span class="badge badge-sm indicator-item badge-primary text-primary-content font-bold border-none">8</span>
                    </div>
                </div>
                <div tabindex="0" class="card card-compact dropdown-content bg-base-100 z-1 mt-3 w-52 shadow-xl border border-base-200">
                    <div class="card-body">
                        <span class="text-lg font-black tracking-tight text-base-content">8 Items</span>
                        <span class="text-primary font-bold text-sm">Subtotal: $999</span>
                        <div class="card-actions mt-2">
                            <a href="/Cart" class="btn btn-primary btn-block text-primary-content font-black tracking-widest uppercase text-[10px] rounded-full">View cart</a>
                        </div>
                    </div>
                </div>
            </div>

            <div class="h-6 w-px bg-base-content/10 hidden sm:block"></div>

            @if (User?.Identity?.IsAuthenticated == true)
            {
                <!-- User Profile Dropdown -->
                <div class="dropdown dropdown-end">
                    <div tabindex="0" role="button" class="btn btn-ghost btn-circle text-base-content/70 hover:text-primary">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-7 h-7">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M17.982 18.725A7.488 7.488 0 0 0 12 15.75a7.488 7.488 0 0 0-5.982 2.975m11.963 0a9 9 0 1 0-11.963 0m11.963 0A8.966 8.966 0 0 1 12 21a8.966 8.966 0 0 1-5.982-2.275M15 9.75a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
                        </svg>
                    </div>
                    <ul tabindex="0" class="menu menu-sm dropdown-content bg-base-100 rounded-box z-1 mt-3 w-52 p-2 shadow-xl border border-base-200 font-bold uppercase text-[10px] tracking-widest text-base-content">
                        <li>
                            <a href="/Profile" class="justify-between py-3 hover:text-primary">
                                Profile
                                <span class="badge badge-primary badge-sm text-[8px] text-primary-content border-none">New</span>
                            </a>
                        </li>
                        <li><a href="/Settings" class="py-3 hover:text-primary">Settings</a></li>
                        <li><a href="/Auth/Logout" class="py-3 text-error hover:text-error/80">Logout</a></li>
                    </ul>
                </div>
            }
            else
            {
                <!-- Login & Register -->
                <div class="flex items-center gap-1">
                    <a asp-page="/Auth/Login" class="btn btn-ghost btn-sm font-black uppercase text-[10px] tracking-widest text-base-content/70 hover:text-primary">Login</a>
                    <a asp-page="/Auth/Register" class="btn btn-primary btn-sm rounded-full px-6 font-black uppercase text-[10px] tracking-widest text-primary-content">Register</a>
                </div>
            }
        </div>
    </div>

    <!-- Bottom Row View Component -->
    <vc:category-navigation></vc:category-navigation>
</header>
