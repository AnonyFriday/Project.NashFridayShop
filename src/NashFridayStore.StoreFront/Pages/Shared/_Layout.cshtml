<!DOCTYPE html>
<html lang="en" data-theme="cmyk">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - NashFriday Store</title>
    
    <!-- Tailwind 4 + DaisyUI 5 -->
    <script src="https://cdn.jsdelivr.net/npm/@@tailwindcss/browser@@4"></script>
    <link href="https://cdn.jsdelivr.net/npm/daisyui@@5.0.0-beta.8/daisyui.css" rel="stylesheet" type="text/css" />
    
    <!-- Geist Font -->
    <link href="https://cdn.jsdelivr.net/npm/geist@1.3.0/dist/fonts/geist-sans/style.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/geist@1.3.0/dist/fonts/geist-mono/style.css" rel="stylesheet">

    <!-- THE NUCLEAR OVERRIDE -->
    <style type="text/css">
        :root, [data-theme="cmyk"] {
            /* We use !important to make sure we win the fight against the linked CSS */
            --color-primary: #d6001c !important;
            --color-primary-content: oklch(100% 0.026 337.6) !important;
            
            --color-base-100: oklch(100% 0 0) !important; 
            --color-base-200: oklch(95% 0 0) !important;
            --color-base-300: oklch(90% 0 0) !important;
            --color-base-content: oklch(20% 0 0) !important;

            --color-secondary: oklch(84.1% 0.119 22.216) !important;
            --color-secondary-content: oklch(35.9% 0.04 359.339) !important;

            --color-accent: oklch(94.228% 0.189 105.306) !important;
            --color-accent-content: oklch(18.845% 0.037 105.306) !important;

            --color-neutral: oklch(21.778% 0 0) !important;
            --color-neutral-content: oklch(84.355% 0 0) !important;

            --color-info: oklch(68.475% 0.094 217.284) !important;
            --color-info-content: oklch(13.695% 0.018 217.284) !important;

            --color-success: oklch(46.949% 0.162 321.406) !important;
            --color-success-content: oklch(89.389% 0.032 321.406) !important;

            --color-warning: oklch(71.236% 0.159 52.023) !important;
            --color-warning-content: oklch(14.247% 0.031 52.023) !important;

            --color-error: oklch(62.013% 0.208 28.717) !important;
            --color-error-content: oklch(12.402% 0.041 28.717) !important;

            --radius-selector: 1rem !important;
            --radius-field: 0.5rem !important;
            --radius-box: 1rem !important;
        }

        @@theme {
            /* Map Tailwind to the forced variables */
            --color-primary: var(--color-primary);
            --color-secondary: var(--color-secondary);
            --color-accent: var(--color-accent);
            --color-neutral: var(--color-neutral);
            --color-base-100: var(--color-base-100);
            
            --font-sans: "Geist Sans", ui-sans-serif, system-ui;
            --font-mono: "Geist Mono", ui-monospace, SFMono-Regular;
        }

        @@layer base {
            body {
                @@apply font-sans antialiased bg-base-100 text-base-content;
            }
        }
        
        .glass-nav {
            @@apply bg-base-100/70 backdrop-blur-lg border-b border-base-200;
        }
    </style>

    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="min-h-screen flex flex-col">
    <header class="sticky top-0 z-50">
        <div class="navbar glass-nav px-4 md:px-12 py-4">
            <div class="navbar-start">
                <a asp-page="/Index" class="hover:opacity-80 transition-opacity">
                    <img src="~/images/nashfridayshop_logo.svg" alt="NashFriday Store" class="h-10 md:h-12 w-auto" />
                </a>
            </div>

            <div class="navbar-center hidden lg:flex">
                <ul class="menu menu-horizontal px-1 font-bold text-[11px] uppercase tracking-[0.2em] gap-6">
                    <li><a asp-page="/Index" class="hover:text-primary transition-colors text-base-content">Home</a></li>
                    <li><a asp-page="/Collections" class="hover:text-primary transition-colors text-base-content">Collections</a></li>
                    <li><a asp-page="/Story" class="hover:text-primary transition-colors text-base-content">Our Story</a></li>
                </ul>
            </div>
            
            <div class="navbar-end gap-6">
                <div class="dropdown dropdown-end">
                    <div tabIndex="0" role="button" class="btn btn-ghost btn-circle">
                        <div class="indicator">
                            <span class="text-[10px] font-black tracking-tighter uppercase">Cart</span>
                            <span class="badge badge-sm indicator-item badge-primary font-bold border-none text-primary-content">0</span>
                        </div>
                    </div>
                </div>

                <div class="h-6 w-[1px] bg-base-content/10"></div>

                <a asp-page="/Auth/Login" class="btn btn-primary btn-sm rounded-full px-8 font-black uppercase text-[10px] tracking-widest shadow-xl shadow-primary/10 hover:scale-105 transition-all text-primary-content">
                    Login
                </a>
            </div>
        </div>
    </header>

    <main role="main" class="grow">
        @RenderBody()
    </main>

    <footer class="footer footer-center p-16 bg-neutral text-neutral-content mt-20">
        <div class="max-w-md">
            <h2 class="text-2xl font-black italic tracking-tighter mb-4 uppercase text-neutral-content">NashFriday Souvenirs<span class="text-primary not-italic">.</span></h2>
            <p class="font-medium text-lg leading-relaxed opacity-70 italic text-neutral-content">
                "Curating memories from around the world, delivered with love to your doorstep."
            </p>
        </div>
        <nav class="grid grid-flow-col gap-10 font-bold text-[10px] uppercase tracking-[0.3em] mt-10 opacity-60 text-neutral-content">
            <a class="link link-hover" asp-page="/Shipping">Shipping</a>
            <a class="link link-hover" asp-page="/Returns">Returns</a>
            <a class="link link-hover" asp-page="/Contact">Contact</a>
        </nav> 
        <aside class="mt-16">
            <p class="text-[9px] uppercase tracking-[0.4em] opacity-30 font-bold text-neutral-content">© @DateTime.Now.Year NashTech Global - Souvenir Division</p>
        </aside>
    </footer>

    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
