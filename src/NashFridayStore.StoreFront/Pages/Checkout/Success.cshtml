@page
@model NashFridayStore.StoreFront.Pages.Checkout.SuccessModel
@{
    ViewData["Title"] = "Order Successful";
}

<div class="container mx-auto px-4 py-24 min-h-[70vh] flex items-center justify-center">
    <div class="max-w-md w-full bg-base-100 p-12 rounded-[3rem] border border-base-200 shadow-2xl text-center">
        <div
            class="w-24 h-24 bg-success/10 text-success rounded-full flex items-center justify-center mx-auto mb-8 animate-bounce">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="3"
                 stroke="currentColor" class="w-12 h-12">
                <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
            </svg>
        </div>
        
        <h1 class="text-4xl font-black mb-4 tracking-tight">Thank You!</h1>
        <p class="text-base-content/60 font-medium mb-10 leading-relaxed">
            Your order has been placed successfully. We've sent a confirmation email to your inbox.
        </p>

        <div class="space-y-4">
            <a asp-page="/Index"
                   class="btn btn-primary btn-block rounded-full h-14 text-primary-content font-black uppercase tracking-widest shadow-lg shadow-primary/20 hover:scale-[1.02] transition-all">
                Back to Home
            </a>
        </div>
    </div>
</div>
