@page
@model NashFridayStore.StoreFront.Pages.Checkout.IndexModel
@{
    ViewData["Title"] = "Checkout";
}

<div class="container mx-auto px-4 py-12 min-h-screen">
    <div class="max-w-5xl mx-auto">
        <h1 class="text-4xl font-black mb-10 tracking-tight">Checkout</h1>

        <div class="grid grid-cols-1 lg:grid-cols-3 gap-12">
            <!-- Checkout Form -->
            <div class="lg:col-span-2">
                <form method="post" hx-post="" hx-swap="outerHTML"
                      class="space-y-8 bg-base-100 p-8 rounded-3xl border border-base-200 shadow-sm">
                    <div class="space-y-6">
                        <h2 class="text-2xl font-black tracking-tight border-b border-base-200 pb-4">Shipping
                            Information</h2>
                            <div class="form-control w-full">
                                <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4">
                                    <label class="label sm:w-1/3 shrink-0">
                                        <span class="label-text font-bold">Full Name</span>
                                    </label>
                                    <input asp-for="CheckoutRequest.CustomerName" type="text"
                                           placeholder="e.g. John Doe"
                                           class="input input-bordered w-full flex-1 rounded-2xl focus:input-primary h-14"
                                           required />
                                    <span asp-validation-for="CheckoutRequest.CustomerName"
                                          class="text-error text-xs mt-1 block"></span>
                                </div>
                            </div>

                            <div class="form-control w-full">
                                <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4">
                                    <label class="label sm:w-1/3 shrink-0">
                                        <span class="label-text font-bold">Email Address</span>
                                    </label>
                                    <input asp-for="CheckoutRequest.CustomerEmail" type="email"
                                           placeholder="e.g. john@example.com"
                                           class="input input-bordered w-full flex-1 rounded-2xl focus:input-primary h-14"
                                           required />
                                    <span asp-validation-for="CheckoutRequest.CustomerEmail"
                                          class="text-error text-xs mt-1 block"></span>
                                </div>
                            </div>

                            <div class="form-control w-full">
                                <div class="flex flex-col sm:flex-row gap-4">
                                    <label class="label sm:w-1/3 shrink-0 sm:pt-4">
                                        <span class="label-text font-bold">Delivery Address</span>
                                    </label>
                                    <textarea asp-for="CheckoutRequest.DeliveryAddress"
                                              placeholder="Enter your full address"
                                              class="textarea textarea-bordered w-full flex-1 rounded-2xl focus:textarea-primary min-h-[120px] p-4 leading-relaxed"
                                              required></textarea>
                                    <span asp-validation-for="CheckoutRequest.DeliveryAddress"
                                          class="text-error text-xs mt-1 block"></span>
                                </div>
                            </div>

                            <div class="form-control w-full">
                                <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4">
                                    <label class="label sm:w-1/3 shrink-0">
                                        <span class="label-text font-bold">Phone Number</span>
                                    </label>
                                    <input asp-for="CheckoutRequest.PhoneNumber" type="tel"
                                           placeholder="e.g. +84 123 456 789"
                                           class="input input-bordered w-full flex-1 rounded-2xl focus:input-primary h-14"
                                           required />
                                    <span asp-validation-for="CheckoutRequest.PhoneNumber"
                                          class="text-error text-xs mt-1 block"></span>
                                </div>
                            </div>
                        </div>

                        <div class="pt-6">
                            <button type="submit"
                                    class="btn btn-primary btn-block rounded-full h-14 text-primary-content font-black uppercase tracking-widest shadow-xl shadow-primary/20 hover:scale-[1.01] transition-all">
                                Place Order & Pay
                            </button>
                        </div>
                    </form>
                </div>

                <!-- Order Summary Sidebar -->
                <div class="lg:col-span-1">
                    <div class="bg-base-200 rounded-3xl p-8 border border-base-200 sticky top-8">
                        <h2 class="text-2xl font-black mb-6 tracking-tight">Order Summary</h2>
                    
                        <div class="space-y-4 max-h-[400px] overflow-y-auto mb-6 pr-2">
                            @if (Model.Cart != null)
                            {
                                @foreach (var item in Model.Cart.Items)
                                {
                                    <div class="flex gap-4 items-center">
                                        <div
                                            class="w-16 h-16 bg-base-100 rounded-xl overflow-hidden flex-shrink-0 border border-base-300">
                                            <img src="@(string.IsNullOrEmpty(item.ImageUrl) ? $"https://placehold.co/100x100/png?text={item.ProductName.Replace(" ", "+")}" : item.ImageUrl)"
                                                 class="w-full h-full object-cover" alt="@item.ProductName" />
                                        </div>
                                        <div class="flex-1 min-w-0">
                                            <p class="font-bold truncate text-sm">@item.ProductName</p>
                                            <p class="text-xs text-base-content/50 font-bold">Qty: @item.Quantity</p>
                                        </div>
                                        <div class="text-right">
                                            <p class="font-black text-sm">$@((item.PriceInUsd * item.Quantity).ToString("F2"))</p>
                                        </div>
                                    </div>
                                }
                            }
                        </div>

                        <div class="space-y-4 border-t border-base-content/10 pt-6">
                            <div class="flex justify-between text-base-content/60">
                                <span class="font-bold">Subtotal</span>
                                <span
                                class="font-black text-base-content">$@Model.Cart?.TotalPriceInUsd.ToString("F2")</span>
                            </div>
                            <div class="flex justify-between text-base-content/60">
                                <span class="font-bold">Shipping</span>
                                <span class="font-black text-success uppercase text-xs tracking-widest mt-1">Free</span>
                            </div>
                            <div class="border-t border-base-content/10 pt-4 mt-4">
                                <div class="flex justify-between items-baseline">
                                    <span class="text-lg font-black uppercase tracking-widest">Total</span>
                                    <span
                                    class="text-3xl font-black text-primary">$@Model.Cart?.TotalPriceInUsd.ToString("F2")</span>
                                </div>
                            </div>
                        </div>

                        <div class="mt-8 flex flex-col items-center gap-4">
                            <div
                                class="flex items-center gap-2 text-[10px] uppercase tracking-widest font-bold text-base-content/40">
                                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5"
                                     stroke="currentColor" class="w-3 h-3">
                                    <path stroke-linecap="round" stroke-linejoin="round"
                                          d="M16.5 10.5V6.75a4.5 4.5 0 1 0-9 0V10.5m-2.25 13.5h13.5c.621 0 1.125-.504 1.125-1.125V11.25c0-.621-.504-1.125-1.125-1.125H4.875c-.621 0-1.125.504-1.125 1.125v11.25c0 .621.504 1.125 1.125 1.125Z" />
                                </svg>
                                Secure Checkout via Stripe
                            </div>
                            <img src="https://upload.wikimedia.org/wikipedia/commons/b/ba/Stripe_Logo%2C_revised_2016.svg"
                                 class="h-5 grayscale opacity-50" alt="Stripe" />
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    @section Scripts {
        <partial name="_ValidationScriptsPartial" />
    }
