@page
@model NashFridayStore.StoreFront.Pages.Profile.IndexModel
@{
    ViewData["Title"] = "My Profile";
}
@inject IAccountApiClient AccountApiClient

<div class="container mx-auto px-4 py-12">
    <div class="max-w-2xl mx-auto">
        <h1 class="text-4xl font-black mb-10 tracking-tight">My Profile</h1>

        <div class="bg-base-100 rounded-3xl border border-base-200 shadow-sm overflow-hidden">
            <!-- Header section -->
            <div class="bg-base-200/50 p-8 flex items-center gap-6 border-b border-base-200">
                @if (!string.IsNullOrEmpty(Model.Profile.ImageUrl))
                {
                    <div class="w-24 h-24 rounded-2xl overflow-hidden border-4 border-base-100 shadow-sm">
                        <img src="@Model.Profile.ImageUrl" alt="@Model.Profile.FullName" class="w-full h-full object-cover" />
                    </div>
                }
                else
                {
                    <div class="w-24 h-24 bg-primary rounded-2xl flex items-center justify-center text-primary-content border-4 border-base-100 shadow-sm">
                        <span class="text-4xl font-black">@(Model.Profile.FullName?[0].ToString().ToUpper() ?? Model.Profile.Email?[0].ToString().ToUpper() ?? "?")</span>
                    </div>
                }
                <div>
                    <h2 class="text-3xl font-black tracking-tight">@Model.Profile.FullName</h2>
                    <p class="text-base-content/50 font-medium tracking-wide italic">@@@Model.Profile.UserName</p>
                </div>
            </div>

            <!-- Details Section -->
            <div class="p-8 space-y-8">
                <div class="grid grid-cols-1 md:grid-cols-2 gap-x-12 gap-y-8">
                    <div class="space-y-1">
                        <p class="text-[10px] font-black uppercase tracking-widest text-base-content/40">Full Name</p>
                        <p class="text-lg font-bold">@(Model.Profile.FullName ?? "Not provided")</p>
                    </div>

                    <div class="space-y-1">
                        <p class="text-[10px] font-black uppercase tracking-widest text-base-content/40">Username</p>
                        <p class="text-lg font-bold">@(Model.Profile.UserName ?? "Not provided")</p>
                    </div>

                    <div class="space-y-1">
                        <p class="text-[10px] font-black uppercase tracking-widest text-base-content/40">Email Address</p>
                        <p class="text-lg font-bold">@Model.Profile.Email</p>
                    </div>

                    <div class="space-y-1">
                        <p class="text-[10px] font-black uppercase tracking-widest text-base-content/40">Phone Number</p>
                        <p class="text-lg font-bold">@(Model.Profile.PhoneNumber ?? "Not provided")</p>
                    </div>

                    <div class="space-y-1">
                        <p class="text-[10px] font-black uppercase tracking-widest text-base-content/40">Customer ID</p>
                        <p class="font-mono text-sm bg-base-200 px-3 py-1 rounded-lg inline-block text-base-content/70">@Model.Profile.CustomerId</p>
                    </div>

                    <div class="space-y-2">
                        <p class="text-[10px] font-black uppercase tracking-widest text-base-content/40">Account Roles</p>
                        <div class="flex flex-wrap gap-2">
                            @foreach (var role in Model.Profile.Roles ?? [])
                            {
                                <span class="badge badge-primary badge-outline font-black uppercase text-[10px] tracking-widest px-3 py-3">@role</span>
                            }
                        </div>
                    </div>
                </div>
                <div class="pt-8 border-t border-base-200 flex flex-wrap gap-4 items-center justify-between">
                    <a href="/Products" class="btn btn-ghost rounded-2xl px-6 font-black uppercase tracking-widest text-xs gap-2">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-4 h-4">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5 3 12m0 0 7.5-7.5M3 12h18" />
                        </svg>
                        Back to Shopping
                    </a>

                    <form action="@AccountApiClient.GetLogoutRedirectAddress("/Index")" method="post">
                        <button type="submit" class="btn btn-error btn-outline rounded-2xl px-8 font-black uppercase tracking-widest text-xs">
                            Logout Account
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
