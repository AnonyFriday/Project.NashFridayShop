@page
@model IndexModel

@{
    ViewData["Title"] = "Home page";

    // Asymmetrical "Bento Box" Layout Classes for 10 items
    var bentoClasses = new[] {
        "md:col-span-2 md:row-span-2", // large hero
        "md:col-span-1 md:row-span-1", // standard
        "md:col-span-1 md:row-span-1", // standard
        "md:col-span-1 md:row-span-2", // tall
        "md:col-span-1 md:row-span-1", // standard
        "md:col-span-2 md:row-span-1", // wide
        "md:col-span-1 md:row-span-1", // standard
        "md:col-span-1 md:row-span-1", // standard
        "md:col-span-1 md:row-span-1", // standard
        "md:col-span-2 md:row-span-1"  // wide
    };
}

<div class="container mx-auto px-8 py-12">
    <!-- Section Header -->
    <partial name="~/Pages/Shared/PartialViews/SectionHeader/_SectionHeader.cshtml"
             model="@Model.TopRatedSectionHeader" />

    <!-- Grid -->
    <div class="grid grid-cols-1 md:grid-cols-4 gap-4 md:auto-rows-[250px]">
        @if (Model.TopProducts.Any())
        {
            @for (int i = 0; i < Model.TopProducts.Count; i++)
            {
                var product = Model.TopProducts[i];
                var gridClass = bentoClasses[i];

                <a asp-page="/Products/Details/Index" asp-route-ProductId="@product.Id"
                       class="group relative overflow-hidden rounded-2xl bg-base-300 @gridClass shadow-md hover:shadow-2xl hover:-translate-y-1 transition-all duration-300 block h-full min-h-62.5 relative">

                    @* Badge *@
                    @if (product.IsNew)
                    {
                        <span
                            class="absolute top-4 -right-8 z-10 rotate-45 bg-primary px-10 py-1 text-center text-xs font-bold text-white shadow-lg">
                            NEW
                        </span>
                    }

                    @* Image Background *@
                    <img src="@(string.IsNullOrEmpty(product.ImageUrl) ? $"https://placehold.co/600x600/png?text={product.Name.Replace(" ", "+")}" : product.ImageUrl)"
                         alt="@product.Name"
                         class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-110" />
                    
                    @* Overlay Gradient for Text Readability *@
                    <div
                        class="absolute inset-0 bg-linear-to-t from-black/90 via-black/40 to-black/10 opacity-70 group-hover:opacity-90 transition-opacity duration-300">
                    </div>

                    @* Content (Bottom Left) *@
                    <div class="absolute inset-0 p-6 flex flex-col justify-end">
                        <div class="flex items-center gap-2 mb-2">
                            
                            @* Star Rating Badge *@
                            <div class="badge badge-primary gap-1 font-bold border-none shadow-lg">
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3" viewBox="0 0 20 20" fill="currentColor">
                                    <path
                                    d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                                </svg>
                                @product.AverageStars
                            </div>
                            
                            @if (product.Quantity < 10)
                            {
                                <div
                                    class="badge badge-error badge-sm uppercase tracking-widest text-[8px] font-bold text-white border-none shadow-lg">
                                    Low Stock</div>
                                }
                            </div>
                        
                            <h3
                                class="text-white font-black text-xl md:text-2xl uppercase tracking-widest group-hover:text-primary transition-colors line-clamp-2 mb-1">
                                @product.Name</h3>
                                <p class="text-white/90 font-bold text-lg">@product.PriceUsd.ToString("C")</p>
                            </div>
                        </a>
                    }
                }
        else
                {
                    <div class="col-span-full flex flex-col items-center justify-center py-20 text-base-content/50">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5"
                             stroke="currentColor" class="w-12 h-12 mb-4 opacity-50">
                            <path stroke-linecap="round" stroke-linejoin="round"
                                  d="M2.25 3h1.386c.51 0 .955.343 1.087.835l.383 1.437M7.5 14.25a3 3 0 0 0-3 3h15.75m-12.75-3h11.218c1.121-2.3 2.1-4.684 2.924-7.138a60.114 60.114 0 0 0-16.536-1.84M7.5 14.25 5.106 5.272M6 20.25a.75.75 0 1 1-1.5 0 .75.75 0 0 1 1.5 0Zm12.75 0a.75.75 0 1 1-1.5 0 .75.75 0 0 1 1.5 0Z" />
                        </svg>
                        <p class="font-bold tracking-widest uppercase">No products available at the moment.</p>
                    </div>
                }
            </div>
        </div>
