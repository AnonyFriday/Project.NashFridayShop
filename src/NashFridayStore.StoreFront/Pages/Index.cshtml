@page
@model IndexModel
@{
    ViewData["Title"] = "Treasures & Memories";
}

<div class="bg-base-100">
    <!-- Clean Hero Section -->
    <section class="max-w-[1400px] mx-auto px-4 md:px-12 py-12 md:py-24">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
            <div class="order-2 lg:order-1">
                <span class="text-[10px] font-bold tracking-[0.4em] text-primary uppercase mb-6 block">Est. 2026</span>
                <h1 class="text-5xl md:text-6xl font-black tracking-tight text-base-content leading-tight mb-8">
                    Beautifully crafted <br/>
                    <span class="text-primary italic">souvenirs</span> for the <br/>
                    modern collector.
                </h1>
                <p class="text-lg text-base-content/60 max-w-md mb-10 leading-relaxed font-medium italic">
                    Hand-picked treasures that capture the essence of your journeys. Minimalist design, maximalist memories.
                </p>
                <div class="flex gap-4">
                    <a href="/Collections" class="btn btn-primary btn-md px-10 rounded-full font-bold uppercase tracking-widest">Shop Collection</a>
                    <a href="/About" class="btn btn-ghost btn-md px-10 rounded-full font-bold uppercase tracking-widest">Our Story</a>
                </div>
            </div>
            
            <div class="order-1 lg:order-2">
                <div class="rounded-2xl overflow-hidden shadow-2xl shadow-primary/5 aspect-4/3 relative group">
                    <img src="~/images/souvenir_hero.png" alt="Artisan Souvenirs" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-1000" />
                    <div class="absolute inset-0 border-20 border-white/10 pointer-events-none"></div>
                </div>
            </div>
        </div>
    </section>

    <!-- Simple Categories -->
    <section class="bg-base-200/50 py-24">
        <div class="max-w-[1400px] mx-auto px-4 md:px-12">
            <div class="flex justify-between items-center mb-16">
                <h2 class="text-xs font-black uppercase tracking-[0.4em] text-primary/50">Featured Collections</h2>
                <a href="/Collections" class="text-[10px] font-bold uppercase tracking-widest border-b border-primary/20 pb-1 hover:border-primary transition-all">View All</a>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-3 gap-12">
                <!-- Collection 1 -->
                <a href="#" class="group block">
                    <div class="aspect-[1/1] bg-white rounded-xl mb-6 overflow-hidden shadow-sm group-hover:shadow-2xl transition-all duration-500 border border-base-content/5">
                        <div class="w-full h-full bg-base-300 flex items-center justify-center opacity-10 text-xl font-black uppercase italic tracking-tighter">Ceramics</div>
                    </div>
                    <h3 class="text-lg font-black tracking-tight uppercase mb-1">Artisan Ceramics</h3>
                    <p class="text-[10px] text-base-content/40 uppercase tracking-widest font-black">12 Items • From $29</p>
                </a>

                <!-- Collection 2 -->
                <a href="#" class="group block translate-y-0 md:translate-y-8">
                    <div class="aspect-[1/1] bg-white rounded-xl mb-6 overflow-hidden shadow-sm group-hover:shadow-2xl transition-all duration-500 border border-primary/10">
                        <div class="w-full h-full bg-base-300 flex items-center justify-center opacity-10 text-xl font-black uppercase italic tracking-tighter">Textiles</div>
                    </div>
                    <h3 class="text-lg font-black tracking-tight uppercase mb-1">Woven Textiles</h3>
                    <p class="text-[10px] text-base-content/40 uppercase tracking-widest font-black">8 Items • From $45</p>
                </a>

                <!-- Collection 3 -->
                <a href="#" class="group block">
                    <div class="aspect-[1/1] bg-white rounded-xl mb-6 overflow-hidden shadow-sm group-hover:shadow-2xl transition-all duration-500 border border-base-content/5">
                        <div class="w-full h-full bg-base-300 flex items-center justify-center opacity-10 text-xl font-black uppercase italic tracking-tighter">Woodwork</div>
                    </div>
                    <h3 class="text-lg font-black tracking-tight uppercase mb-1">Hand-carved Wood</h3>
                    <p class="text-[10px] text-base-content/40 uppercase tracking-widest font-black">15 Items • From $18</p>
                </a>
            </div>
        </div>
    </section>

    <!-- Clean Newsletter -->
    <section class="py-32 text-center">
        <div class="max-w-xl mx-auto px-4">
            <h2 class="text-3xl font-black tracking-tight uppercase mb-4">Join our <span class="text-primary italic">Journal</span></h2>
            <p class="text-base-content/50 mb-10 font-medium italic">Be the first to know about new artisan arrivals and travel stories.</p>
            <div class="flex gap-2 p-1.5 bg-base-200 rounded-full max-w-md mx-auto border border-base-content/5 shadow-inner">
                <input type="email" placeholder="Your email address" class="bg-transparent px-6 py-2 outline-none flex-grow text-sm font-bold placeholder:text-base-content/20" />
                <button class="btn btn-primary rounded-full px-10 btn-sm h-10 uppercase font-black text-[10px] tracking-widest shadow-lg shadow-primary/20">Join</button>
            </div>
        </div>
    </section>
</div>
